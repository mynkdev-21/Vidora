<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:gravity="center_horizontal"
    android:paddingTop="60dp"
    android:paddingHorizontal="28dp"
    android:paddingBottom="28dp">

    <!-- Logo -->
    <ImageView
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:src="@drawable/logo_wordmark"
        android:scaleType="fitCenter"
        android:layout_marginBottom="50dp"
        android:layout_gravity="center"
        android:contentDescription="Vidora" />

    <!-- Title -->
    <TextView
        android:fitsSystemWindows="true"
    android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome back"
        android:textSize="24sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="6dp" />

    <TextView
        android:fitsSystemWindows="true"
    android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Log in to your Vidora account"
        android:textSize="14sp"
        android:textColor="@color/text_muted"
        android:layout_marginBottom="28dp" />

    <!-- Error -->
    <TextView
        android:id="@+id/tv_error"
        android:fitsSystemWindows="true"
    android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/red_light"
        android:background="@drawable/bg_error"
        android:padding="12dp"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <!-- Contact Support (shown when banned) -->
    <TextView
        android:id="@+id/btn_contact_support"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💬  Contact Support"
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_btn_outline_purple"
        android:padding="12dp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="14dp" />

    <!-- Email -->
    <TextView
        android:fitsSystemWindows="true"
    android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Email address"
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/et_email"
        android:fitsSystemWindows="true"
    android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="you@example.com"
        android:textColorHint="@color/text_muted"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:background="@drawable/bg_input"
        android:padding="14dp"
        android:inputType="textEmailAddress"
        android:layout_marginBottom="16dp" />

    <!-- Password -->
    <TextView
        android:fitsSystemWindows="true"
    android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Password"
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/et_password"
        android:fitsSystemWindows="true"
    android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="••••••••"
        android:textColorHint="@color/text_muted"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:background="@drawable/bg_input"
        android:padding="14dp"
        android:inputType="textPassword"
        android:layout_marginBottom="24dp" />

    <!-- Login button -->
    <TextView
        android:id="@+id/btn_login"
        android:fitsSystemWindows="true"
    android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Log In"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_btn_purple"
        android:padding="16dp"
        android:gravity="center"
        android:layout_marginBottom="14dp" />

    <!-- Forgot password -->
    <TextView
        android:id="@+id/btn_forgot_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot password?"
        android:textSize="13sp"
        android:textColor="@color/purple_light"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- Go to signup -->
    <TextView
        android:id="@+id/btn_go_signup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Don't have an account? Sign up"
        android:textSize="13sp"
        android:textColor="@color/purple_light"
        android:layout_gravity="center" />

</LinearLayout>
