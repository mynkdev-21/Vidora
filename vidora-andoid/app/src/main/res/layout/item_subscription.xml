<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <!-- Avatar -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="14dp">
        <TextView
            android:id="@+id/tv_sub_avatar_letter"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_avatar_circle" />
        <ImageView
            android:id="@+id/iv_sub_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Name + file count -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tv_sub_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium" />
        <TextView
            android:id="@+id/tv_sub_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Bell toggle -->
    <ImageView
        android:id="@+id/iv_sub_bell"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="4dp"
        android:src="@drawable/ic_bell_on"
        android:contentDescription="Toggle notifications" />

    <!-- Unsubscribe -->
    <TextView
        android:id="@+id/btn_sub_unsub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Subscribed"
        android:textSize="11sp"
        android:textColor="@color/purple_light"
        android:background="@drawable/bg_btn_subscribed"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:layout_marginStart="8dp" />
</LinearLayout>
