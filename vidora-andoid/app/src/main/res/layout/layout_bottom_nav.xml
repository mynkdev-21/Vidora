<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottom_nav"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/nav_bg"
    android:paddingHorizontal="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_home" android:tint="@color/text_dim" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Home" android:textSize="11sp" android:textColor="@color/text_dim" android:layout_marginTop="4dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_search"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_feed" android:tint="@color/text_dim" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Feed" android:textSize="11sp" android:textColor="@color/text_dim" android:layout_marginTop="4dp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/nav_add"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">
        <androidx.cardview.widget.CardView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            app:cardCornerRadius="15dp"
            app:cardBackgroundColor="@color/purple_primary"
            app:cardElevation="6dp">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_add"
                android:tint="@color/white" />
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/nav_saved"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_bookmark" android:tint="@color/text_dim" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Saved" android:textSize="11sp" android:textColor="@color/text_dim" android:layout_marginTop="4dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_person" android:tint="@color/text_dim" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Profile" android:textSize="11sp" android:textColor="@color/text_dim" android:layout_marginTop="4dp" />
    </LinearLayout>
</LinearLayout>
