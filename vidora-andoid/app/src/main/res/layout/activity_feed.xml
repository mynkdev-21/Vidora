<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:padding="6dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Your Feed"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="12dp" />

        <TextView
            android:id="@+id/btn_all_subs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All"
            android:textSize="12sp"
            android:textColor="@color/purple_light"
            android:background="@drawable/bg_btn_subscribed"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp" />
    </LinearLayout>

    <!-- Subscribed Creators Horizontal Scroll -->
    <HorizontalScrollView
        android:id="@+id/scroll_creators"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingVertical="8dp"
        android:visibility="gone">
        <LinearLayout
            android:id="@+id/layout_creators"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical" />
    </HorizontalScrollView>

    <!-- Divider -->
    <View
        android:id="@+id/divider_creators"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        android:visibility="gone" />

    <!-- Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_feed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/purple_primary"
            android:visibility="gone" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="40dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_feed"
                android:tint="#20A78BFA"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your feed is empty"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subscribe to creators from the player screen to see their latest uploads here."
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:gravity="center"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom Nav -->
    <include layout="@layout/layout_bottom_nav" />
</LinearLayout>
