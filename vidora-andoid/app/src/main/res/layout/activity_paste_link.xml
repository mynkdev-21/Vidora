<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Top bar: Logo + Settings -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="14dp">

        <ImageView
            android:layout_width="130dp"
            android:layout_height="32dp"
            android:src="@drawable/logo_wordmark"
            android:scaleType="fitStart"
            android:contentDescription="Vidora" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/btn_settings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_person"
            android:padding="8dp"
            android:background="@drawable/bg_icon_button_purple"
            android:contentDescription="Settings" />
    </LinearLayout>

    <!-- Banner Ad -->
    <com.google.android.gms.ads.AdView
        android:id="@+id/ad_banner"
        app:adSize="BANNER"
        app:adUnitId="ca-app-pub-3940256099942544/6300978111"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal" />

    <!-- Link input card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_input"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_link"
            android:tint="@color/text_muted"
            android:contentDescription="Link" />

        <EditText
            android:id="@+id/et_link"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Enter link here …"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:background="@null"
            android:inputType="textUri"
            android:singleLine="true"
            android:layout_marginStart="12dp" />

        <ImageView
            android:id="@+id/btn_play"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_search"
            android:tint="@color/purple_light"
            android:contentDescription="Go" />
    </LinearLayout>

    <!-- Recent History header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Recent History"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/btn_clear_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear All"
            android:textSize="13sp"
            android:textColor="@color/purple_light" />
    </LinearLayout>

    <!-- Recent history list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false" />

    <!-- FAB (paste from clipboard) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_paste"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_clipboard"
            android:contentDescription="Paste"
            app:backgroundTint="@color/purple_primary"
            app:tint="@color/white"
            app:fabSize="normal" />
    </FrameLayout>

    <!-- Bottom Navigation (same as home) -->
    <include layout="@layout/layout_bottom_nav" />

</LinearLayout>
