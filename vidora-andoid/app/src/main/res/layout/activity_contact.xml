<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_arrow_back"
            android:padding="8dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Support"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="14dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="30dp">

            <!-- Icon -->
            <LinearLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:background="@drawable/bg_stat_purple">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_share"
                    android:tint="@color/purple_light" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send us a Message"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="We'll respond within 24 hours"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:gravity="center"
                android:layout_marginBottom="28dp" />

            <!-- Name -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your Name"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="John Doe"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:background="@drawable/bg_input"
                android:padding="14dp"
                android:inputType="textPersonName"
                android:layout_marginBottom="14dp" />

            <!-- Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="you@example.com"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:background="@drawable/bg_input"
                android:padding="14dp"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="14dp" />

            <!-- Message -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Message"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:hint="Describe your issue or question..."
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:background="@drawable/bg_input"
                android:padding="14dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:maxLength="2000"
                android:layout_marginBottom="20dp" />

            <!-- Send button -->
            <TextView
                android:id="@+id/btn_send"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send Message"
                android:textSize="15sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_btn_purple"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- Success message (hidden by default) -->
            <LinearLayout
                android:id="@+id/layout_success"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:padding="20dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_play"
                    android:tint="@color/green_light"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Message Sent!"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="We'll get back to you soon."
                    android:textSize="13sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
