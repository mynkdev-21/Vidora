<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:anim/decelerate_interpolator">
    <rotate
        android:fromDegrees="0"
        android:toDegrees="15"
        android:pivotX="50%"
        android:pivotY="20%"
        android:duration="80" />
    <rotate
        android:fromDegrees="15"
        android:toDegrees="-15"
        android:pivotX="50%"
        android:pivotY="20%"
        android:startOffset="80"
        android:duration="80" />
    <rotate
        android:fromDegrees="-15"
        android:toDegrees="10"
        android:pivotX="50%"
        android:pivotY="20%"
        android:startOffset="160"
        android:duration="80" />
    <rotate
        android:fromDegrees="10"
        android:toDegrees="-10"
        android:pivotX="50%"
        android:pivotY="20%"
        android:startOffset="240"
        android:duration="80" />
    <rotate
        android:fromDegrees="-10"
        android:toDegrees="0"
        android:pivotX="50%"
        android:pivotY="20%"
        android:startOffset="320"
        android:duration="100" />
</set>
